{
  "name": "chronochat",
  "version": "1.2.6",
  "description": "A browser extension for ChatGPT that makes long conversations easier to navigate with search, filters, keyboard shortcuts, and fast jump navigation.",
  "main": "content_script.js",
  "homepage": "https://github.com/sickn33/chronochat",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sickn33/chronochat.git"
  },
  "bugs": {
    "url": "https://github.com/sickn33/chronochat/issues"
  },
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "build": "npm run build:content && npm run build:service-worker && npm run build:style && npm run build:minify",
    "build:content": "node scripts/build-content.js",
    "build:service-worker": "node scripts/build-service-worker.js",
    "build:style": "node scripts/build-style.js",
    "build:minify": "npm run build:minify:js && npm run build:minify:css",
    "build:minify:js": "terser content_script.js -o content_script.min.js --compress --mangle",
    "build:minify:css": "cleancss -o style.min.css style.css",
    "package:extension": "bash scripts/package-extension.sh",
    "test:smoke": "npm run build && node scripts/test-smoke.js",
    "validate": "npm test -- --runInBand && npm run build",
    "prebuild": "echo 'Building production assets...'",
    "postbuild": "echo 'Build complete! Minified files ready.'"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!tests/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 65,
        "lines": 65,
        "statements": 65
      }
    },
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(tests)/)"
    ]
  },
  "keywords": [],
  "author": "ChronoChat",
  "license": "ISC",
  "overrides": {
    "brace-expansion": "^1.1.13",
    "minimatch": "^3.1.4",
    "picomatch": "^2.3.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/chrome": "^0.1.40",
    "babel-jest": "^30.3.0",
    "clean-css-cli": "^5.6.3",
    "docx": "^9.6.1",
    "esbuild": "^0.28.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.59.1",
    "terser": "^5.46.1"
  }
}
